{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "render-jobs",
  "main": "src/index.js",
  "compatibility_date": "2026-07-07",
  "workers_dev": true,

  // Pinned so wrangler does not call /memberships to resolve the account.
  // A user API token cannot read memberships, which blocks every command.
  "account_id": "4fe56b3b11951a260d67361df9b864a0",

  // D1 holds job records. The placeholder below is intentional and repo-safe:
  // CI resolves the real database_id at deploy time (d1 list --json, parsed by
  // scripts/extract-d1-id.mjs) and injects it here before `wrangler deploy`, so
  // the deployed worker binds the real database. A manual `wrangler deploy`
  // straight from the repo needs the real id pasted in first (see README).
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "render-jobs",
      "database_id": "REPLACE_AFTER_D1_CREATE"
    }
  ],

  // R2 holds job assets: render-package.json, locked-product image, outputs.
  "r2_buckets": [
    {
      "binding": "RENDERS",
      "bucket_name": "higher-roads-renders"
    }
  ],

  // Origins allowed to call this worker from the browser. Comma separated.
  // During the proving phase this is convenience, not security. Real auth,
  // rate limiting, and cost ceilings are deferred to the GA hardening phase.
  "vars": {
    "ALLOWED_ORIGINS": "https://higher-roads.com,https://www.higher-roads.com",
    "OPENAI_IMAGE_MODEL": "gpt-image-2",
    "OPENAI_IMAGE_SIZE": "1536x864",
    "OPENAI_IMAGE_QUALITY": "medium",
    "OPENAI_IMAGE_OUTPUT_FORMAT": "png"
  },

  // Async render pipeline. The fetch handler produces to render-queue; the
  // queue handler in the same worker consumes it. max_batch_size 1 keeps each
  // heavy OpenAI render in its own invocation. max_retries 2 gives transient
  // OpenAI failures a couple of attempts before the job is marked error.
  "queues": {
    "producers": [
      { "queue": "render-queue", "binding": "RENDER_QUEUE" }
    ],
    "consumers": [
      { "queue": "render-queue", "max_batch_size": 1, "max_batch_timeout": 5, "max_retries": 2 }
    ]
  },

  "observability": {
    "enabled": true
  }
}
